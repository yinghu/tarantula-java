<?xml version="1.0" encoding="UTF-8"?>
<assembly>
  <id>bin</id>
  <formats>
  	<format>tar.gz</format>
  	<format>dir</format>
  </formats>
  <dependencySets>
    <dependencySet>
        <outputDirectory>lib</outputDirectory>
    </dependencySet>
  </dependencySets>
  <fileSets>
  	<fileSet>
      	<directory>src/main/bin</directory>
      	<outputDirectory>bin</outputDirectory>
      	<includes>
        	<include>tarantula.sh</include>
			<include>tarantula_dev.sh</include>
			<include>tarantula.bat</include>
			<include>bootstrap.sh</include>
			<include>gec-agent-1.0.jar</include>
			<include>license.txt</include>
			<include>version.txt</include>
      	</includes>
      	<fileMode>0777</fileMode>
     </fileSet>
     <fileSet>
      	<directory>src/main/conf</directory>
      	<outputDirectory>conf</outputDirectory>
      	<includes>
        	<include>*</include>
			<include>*/*</include>
			<include>*/*/*</include>
      	</includes>
     </fileSet>
      <fileSet>
          <directory>src/main/deploy</directory>
          <outputDirectory>deploy</outputDirectory>
          <includes>
              <include>*</include>
          </includes>
      </fileSet>
     <fileSet>
	  <directory>src/main/lib</directory>
	  <outputDirectory>lib</outputDirectory>
	  <includes>
		  <include>*.jar</include>
	  </includes>
  </fileSet>
	  <fileSet>
		  <directory>src/main/web</directory>
		  <outputDirectory>web</outputDirectory>
		  <includes>
			  <include>*</include>
			  <include>*/*</include>
			  <include>*/*/*</include>
			  <include>*/*/*/*</include>
		  </includes>
	  </fileSet>
  </fileSets>
 
</assembly>
