<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <!--
        Game Lobby Name Rule
        game name : system level unique
        game lobby type id : [game name]-lobby , tag : [game name]/zone[sequence]
        game service type id : [game name]-service, tag : [game name]/mmk
        game data type id : [game name]-data, tag : [game name]/data
        data service name : [game name]-service
        data service data store : [game name]-service
    -->
    <lobby-context>
        <type-id>game-lobby</type-id>
        <type>lobby</type>
        <category>game</category>
        <name>GameLobby</name>
        <access-mode>12</access-mode>
        <deploy-code>1</deploy-code>
        <deploy-priority>15</deploy-priority>
        <description>Tarantula Game Lobby Service</description>
        <application-list>
            <application>
                <type-id>game-lobby</type-id>
                <subtype-id>game-lobby-module</subtype-id>
                <name>GameLobby 1</name>
                <type>application</type>
                <category>game</category>
                <singleton>true</singleton>
                <tag>game/lobby1</tag>
                <class-name>com.tarantula.platform.module.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.game.module.GameZoneModule</module-name>
                <capacity>3</capacity>
                <access-rank>1</access-rank>
                <timer-on-module>1000</timer-on-module>
            </application>
            <application>
                <type-id>game-lobby</type-id>
                <subtype-id>game-lobby-module</subtype-id>
                <name>GameLobby 2</name>
                <type>application</type>
                <category>game</category>
                <singleton>true</singleton>
                <tag>game/lobby2</tag>
                <class-name>com.tarantula.platform.module.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.game.module.GameZoneModule</module-name>
                <capacity>3</capacity>
                <access-rank>2</access-rank>
                <timer-on-module>1000</timer-on-module>
            </application>
        </application-list>
    </lobby-context>
    <lobby-context>
        <type-id>game-service</type-id>
        <type>lobby</type>
        <category>service</category>
        <name>LiveService</name>
        <access-mode>12</access-mode>
        <deploy-code>1</deploy-code>
        <deploy-priority>10</deploy-priority>
        <description>Tarantula Match Making Service</description>
        <application-list>
            <application><!-- Match making app-->
                <type-id>game-service</type-id>
                <subtype-id>game-service-module</subtype-id>
                <name>MatchMaking</name>
                <type>application</type>
                <category>service</category>
                <singleton>true</singleton>
                <tag>game/mmk</tag>
                <class-name>com.tarantula.platform.module.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.game.module.MatchMakingModule</module-name>
            </application>
            <application><!-- stats/leader board app-->
                <type-id>game-service</type-id>
                <subtype-id>game-service-module</subtype-id>
                <name>Statistics</name>
                <type>application</type>
                <category>service</category>
                <singleton>true</singleton>
                <tag>game/stats</tag>
                <class-name>com.tarantula.platform.module.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.game.module.StatisticsModule</module-name>
            </application>
        </application-list>
    </lobby-context>
    <lobby-context>
        <type-id>game-data</type-id>
        <type>lobby</type>
        <category>service</category>
        <name>DataStore</name>
        <access-mode>12</access-mode>
        <deploy-code>1</deploy-code>
        <deploy-priority>20</deploy-priority>
        <description>Tarantula Game Data Service</description>
        <application-list>
            <application><!-- key/value set/get app-->
                <type-id>game-data</type-id>
                <subtype-id>game-data-module</subtype-id>
                <name>JsonDataStore</name>
                <type>application</type>
                <category>service</category>
                <singleton>true</singleton>
                <tag>game/data</tag>
                <class-name>com.tarantula.platform.module.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.game.module.KeyValueDataStoreModule</module-name>
            </application>
        </application-list>
    </lobby-context>
</tarantula>