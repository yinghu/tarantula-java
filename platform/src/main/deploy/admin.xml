<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>admin</type-id>
        <type>lobby</type>
        <category>game</category>
        <tag>admin</tag>
        <icon>assets/gear.png</icon>
        <view-id>game.lobby</view-id>
        <name>Admin</name>
        <access-mode>12</access-mode>
        <deploy-code>1</deploy-code>
        <description>Tarantula Admin Service</description>
        <application-list>
            <application>
                <type-id>admin</type-id>
                <subtype-id>admin-lobby</subtype-id>
                <name>Lobby Admin</name>
                <type>application</type>
                <category>lobby</category>
                <singleton>true</singleton>
                <tag>admin</tag>
                <description>Tarantula Admin Service</description>
                <class-name>com.tarantula.platform.playmode.GameLobbyApplication</class-name>
                <deploy-priority>15</deploy-priority>
                <response-label>admin</response-label>
            </application>
            <application>
                <type-id>admin</type-id>
                <subtype-id>admin-tool</subtype-id>
                <view-id>admin.game</view-id>
                <name>Monitor</name>
                <type>application</type>
                <category>admin</category>
                <singleton>true</singleton>
                <tag>admin-monitor</tag>
                <description>Tarantula Monitor Service</description>
                <class-name>com.tarantula.platform.playmode.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.admin.AdminMonitorModule</module-name>
                <entry-cost>0</entry-cost>
                <capacity>10</capacity>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <response-label>admin</response-label>
            </application>
            <application>
                <type-id>admin</type-id>
                <subtype-id>admin-tool</subtype-id>
                <view-id>admin.game</view-id>
                <name>Admin Setup</name>
                <type>application</type>
                <category>admin</category>
                <singleton>true</singleton>
                <tag>admin-setup</tag>
                <description>Tarantula Admin Tool Service</description>
                <class-name>com.tarantula.platform.playmode.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.admin.AdminSetupModule</module-name>
                <entry-cost>0</entry-cost>
                <capacity>10</capacity>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <response-label>admin</response-label>
            </application>
            <application>
                <type-id>admin</type-id>
                <subtype-id>admin-tool</subtype-id>
                <view-id>admin.game</view-id>
                <name>DataStore</name>
                <type>application</type>
                <category>admin</category>
                <singleton>true</singleton>
                <tag>admin-data-store</tag>
                <description>Tarantula Customer Service</description>
                <class-name>com.tarantula.platform.playmode.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.admin.AdminDataStoreModule</module-name>
                <entry-cost>0</entry-cost>
                <capacity>10</capacity>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <response-label>admin</response-label>
            </application>
        </application-list>
        <view-list>
            <view type="admin.game">
                <property name="flag">HD2</property>
                <property name="moduleFile">html/admin/admin.game.module.js</property>
                <property name="moduleName">AdminGame</property>
                <property name="moduleResourceFile">html/admin/admin.game.view.html</property>
            </view>
            <view type="admin.add.lobby">
                <property name="flag">HD2</property>
                <property name="moduleResourceFile">html/admin/add.lobby.view.html</property>
            </view>
            <view type="admin.add.application">
                <property name="flag">HD2</property>
                <property name="moduleResourceFile">html/admin/add.application.view.html</property>
            </view>
        </view-list>

    </lobby-context>
</tarantula>