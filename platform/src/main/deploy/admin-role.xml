<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>admin-role</type-id>
        <type>lobby</type>
        <category>service</category>
        <name>Admin Role</name>
        <access-mode>12</access-mode>
        <deploy-code>1</deploy-code>
        <description>Tarantula Admin Role Service</description>
        <application-list>
            <application>
                <type-id>admin-role</type-id>
                <subtype-id>admin-role</subtype-id>
                <name>Admin Role</name>
                <type>application</type>
                <category>admin</category>
                <singleton>true</singleton>
                <tag>role/admin</tag>
                <description>Tarantula Admin Role Service</description>
                <module-name>com.tarantula.admin.AdminRoleModule</module-name>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <access-control>30</access-control>
            </application>

        </application-list>
        <configuration-list>
                <configuration tag="admin" type="setup">
                    <property name="maxGameClusterCount">10</property>
                    <property name="maxGameLobbyCount">10</property>
                    <property name="minGameLobbyCount">1</property>
                    <property name="defaultGameLevelCount">3</property>
                    <property name="maxGameLevelCount">10</property>
                </configuration>
                <configuration tag="admin" type="yearlyAccess">
                    <property name="description">Yearly Subscription</property>
                    <property name="price">1980.00</property>
                    <property name="currency">USD</property>
                    <property name="durationMonths">12</property>
                </configuration>
                <configuration tag="admin" type="monthlyAccess">
                    <property name="description">Monthly Subscription</property>
                    <property name="price">180.00</property>
                    <property name="currency">USD</property>
                    <property name="durationMonths">1</property>
                </configuration>
        </configuration-list>
        <view-list>
            <view type="create.game.cluster">
                <property name="moduleResourceFile">admin/create.game.cluster.view.html</property>
            </view>
            <view type="create.access.key">
                <property name="moduleResourceFile">admin/create.access.key.view.html</property>
            </view>
            <view type="game.lobby.list">
                <property name="moduleResourceFile">admin/game.lobby.list.view.html</property>
            </view>
            <view type="game.service.list">
                <property name="moduleResourceFile">admin/game.service.list.view.html</property>
            </view>
            <view type="game.data.list">
                <property name="moduleResourceFile">admin/game.data.list.view.html</property>
            </view>
            <view type="shopping.card">
                <property name="moduleResourceFile">admin/stripe.card.view.html</property>
            </view>
            <view type="game.cluster.launch">
                <property name="moduleResourceFile">admin/game.cluster.launch.view.html</property>
            </view>
            <view type="game.cluster.shutdown">
                <property name="moduleResourceFile">admin/game.cluster.shutdown.view.html</property>
            </view>
            <view type="game.cluster.test">
                <property name="moduleResourceFile">admin/game.cluster.test.view.html</property>
            </view>
            <view type="api.service.statistics">
                <property name="moduleResourceFile">admin/api.service.statistics.view.html</property>
            </view>
            <view type="api.service.items">
                <property name="moduleResourceFile">admin/api.service.items.view.html</property>
            </view>
            <view type="api.service.matchmaking">
                <property name="moduleResourceFile">admin/api.service.matchmaking.view.html</property>
            </view>
        </view-list>

    </lobby-context>
</tarantula>