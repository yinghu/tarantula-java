<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>blackjack</type-id>
        <type>lobby</type>
        <category>game</category>
        <icon>html/blackjack/blackjack_icon.png</icon>
        <view-id>game.lobby</view-id>
        <tag>blackjack</tag><!-- the tag of the game lobby access tag-->
        <name>BlackJack</name>
        <access-mode>12</access-mode>
        <deploy-code>1</deploy-code>
        <description>Tarantula BlackJack Game Service</description>
        <application-list>
            <application>
                <type-id>blackjack</type-id>
                <subtype-id>blackjack</subtype-id>
                <name>BlackJack</name>
                <type>application</type>
                <category>lobby</category>
                <singleton>true</singleton>
                <tag>blackjack</tag>
                <description>Tarantula BlackJack Lobby Service</description>
                <class-name>com.tarantula.platform.playmode.GameLobbyApplication</class-name>
                <deploy-priority>15</deploy-priority>
                <configuration-name>blackjack</configuration-name>
                <response-label>baccarat</response-label>
            </application>
            <application>
                <type-id>blackjack</type-id>
                <subtype-id>blackjack1</subtype-id>
                <view-id>blackjack.game</view-id>
                <name>Daily Fun</name>
                <type>application</type>
                <category>casino</category>
                <description>Tarantula BlackJack Service</description>
                <class-name>com.tarantula.game.casino.BlackJackApplication</class-name>
                <entry-cost>5000</entry-cost>
                <capacity>36</capacity>
                <instances-on-startup-per-partition>1</instances-on-startup-per-partition>
                <max-instances-per-partition>10</max-instances-per-partition>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <max-idles-on-instance>3</max-idles-on-instance>
                <configuration-name>blackjack</configuration-name>
                <configuration-type>v1</configuration-type>
                <leader-board-header>blackjack</leader-board-header>
                <response-label>blackjack</response-label>
            </application>
            <application>
                <type-id>blackjack</type-id>
                <subtype-id>blackjack2</subtype-id>
                <view-id>blackjack.game</view-id>
                <name>VIP</name>
                <type>application</type>
                <category>casino</category>
                <description>Tarantula BlackJack Service</description>
                <class-name>com.tarantula.game.casino.BlackJackApplication</class-name>
                <entry-cost>50000</entry-cost>
                <capacity>20</capacity>
                <instances-on-startup-per-partition>1</instances-on-startup-per-partition>
                <max-instances-per-partition>10</max-instances-per-partition>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <max-idles-on-instance>3</max-idles-on-instance>
                <configuration-name>blackjack</configuration-name>
                <configuration-type>v2</configuration-type>
                <leader-board-header>blackjack</leader-board-header>
                <response-label>blackjack</response-label>
            </application>
            <application>
                <type-id>blackjack</type-id>
                <subtype-id>blackjack3</subtype-id>
                <view-id>blackjack.game</view-id>
                <name>Golden Table</name>
                <type>application</type>
                <category>casino</category>
                <description>Tarantula BlackJack Service</description>
                <class-name>com.tarantula.game.casino.BlackJackApplication</class-name>
                <entry-cost>1000000</entry-cost>
                <capacity>10</capacity>
                <instances-on-startup-per-partition>1</instances-on-startup-per-partition>
                <max-instances-per-partition>10</max-instances-per-partition>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <max-idles-on-instance>3</max-idles-on-instance>
                <configuration-name>blackjack</configuration-name>
                <configuration-type>v3</configuration-type>
                <leader-board-header>blackjack</leader-board-header>
                <response-label>blackjack</response-label>
            </application>
            <application>
                <type-id>blackjack</type-id>
                <subtype-id>blackjack4</subtype-id>
                <view-id>blackjack.game</view-id>
                <name>Moon Light</name>
                <type>application</type>
                <category>casino</category>
                <description>Tarantula BlackJack Service</description>
                <class-name>com.tarantula.game.casino.BlackJackApplication</class-name>
                <entry-cost>1000000</entry-cost>
                <capacity>5</capacity>
                <tournament-enabled>false</tournament-enabled>
                <instances-on-startup-per-partition>1</instances-on-startup-per-partition>
                <max-instances-per-partition>10</max-instances-per-partition>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <max-idles-on-instance>3</max-idles-on-instance>
                <configuration-name>blackjack</configuration-name>
                <configuration-type>v4</configuration-type>
                <leader-board-header>blackjack</leader-board-header>
                <response-label>blackjack</response-label>
            </application>
        </application-list>
        <view-list>
            <view type="blackjack.game">
                <property name="flag">HD2</property>
                <property name="moduleFile">html/blackjack/blackjack.game.module.js</property>
                <property name="moduleName">BlackJackGame</property>
                <property name="moduleResourceFile">html/blackjack/blackjack.game.view.html</property>
            </view>
        </view-list>

        <configuration-list>
            <configuration tag="blackjack" priority="10">
                <blackjack type="v1">
                    <property name="splittable">false</property>
                    <property name="dealerSeatFee">1000</property>
                    <property name="seats">8</property>
                    <property name="deckSize">4</property>
                    <property name="minWager">100</property>
                    <property name="maxWager">1000</property>
                </blackjack>
                <blackjack type="v2">
                    <property name="splittable">false</property>
                    <property name="dealerSeatFee">10000</property>
                    <property name="seats">8</property>
                    <property name="deckSize">4</property>
                    <property name="minWager">5000</property>
                    <property name="maxWager">50000</property>
                </blackjack>
                <blackjack type="v3">
                    <property name="splittable">false</property>
                    <property name="dealerSeatFee">100000</property>
                    <property name="seats">8</property>
                    <property name="deckSize">4</property>
                    <property name="minWager">100000</property>
                    <property name="maxWager">1000000</property>
                </blackjack>
                <blackjack type="v4">
                    <property name="splittable">false</property>
                    <property name="dealerSeatFee">100000</property>
                    <property name="seats">8</property>
                    <property name="deckSize">1</property>
                    <property name="minWager">100000</property>
                    <property name="maxWager">1000000</property>
                </blackjack>
            </configuration>
        </configuration-list>

    </lobby-context>
</tarantula>