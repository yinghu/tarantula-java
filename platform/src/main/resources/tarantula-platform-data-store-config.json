{
    "data-source": {
        "name" : "tarantula",
        "provider" : "com.tarantula.platform.service.persistence.berkeley.BerkeleyJEProvider",
        "properties": [
            {"truncated": false},
            {"dataPath":"tarantula/data"},
            {"integrationPath":"tarantula/integration"},
            {"backupPath":"backup"}
        ]
    },
    "integration-backup-router": {
        "enabled": true,
        "backup-provider":{
            "name": "com.tarantula.platform.service.persistence.mysql.MysqlBackupProvider",
            "properties": [
                {"url": "jdbc:mysql://127.0.0.1:3306"},
                {"database": "tarantula"},
                {"user":"root"},
                {"password": "root"},
                {"poolSize": 8}
            ]
        }
    },
    "data-backup-router": {
        "enabled": true,
        "backup-provider":{
            "name": "com.tarantula.platform.service.persistence.mysql.MysqlBackupProvider",
            "properties": [
                {"url": "jdbc:mysql://127.0.0.1:3306"},
                {"database": "tarantula"},
                {"user":"root"},
                {"password": "root"},
                {"poolSize": 8}
            ]
        }
    }
}