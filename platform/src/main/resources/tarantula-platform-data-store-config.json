            {"integrationPath":"tarantula/integration"},
            {"localPath":"tarantula/local"},
            {"indexPath":"tarantula/index"},
            {"logPath":"tarantula/log"}
        ],
        "migration": {
            "listeners": [
                {"name":"com.tarantula.platform.service.user.UserMigrationListener","enabled": false}
            ]
        }
    }
}