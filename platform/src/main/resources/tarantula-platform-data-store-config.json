{
    "data-source": {
        "name" : "tarantula",
        "provider" : "com.tarantula.platform.service.persistence.berkeley.BerkeleyJEProvider",
        "properties": [
            {"truncated": false},
            {"dataPath":"tarantula/data"},
            {"integrationPath":"tarantula/integration"},
            {"backupPath":"backup"},
            {"maxReplicationNumber": 3},
            {"maxTimerLoop": 10},
            {"maxBytesPerBatch": 10000},
            {"replicationBatchSize": 10},
            {"backupBatchSize": 10},
            {"replicationSyncIntervalSeconds": 3},
            {"cacheSyncIntervalMinutes": 60},
            {"cacheUpdateThreshold": 10000},
            {"backupSyncIntervalSeconds": 10},
            {"diskSyncIntervalSeconds": 60},
            {"syncUpdateThreshold": 10000}
        ]
    },
    "integration-backup-router": {
        "enabled": true,
        "backup-provider-list":[{
            "enabled": false,
            "name": "rabbitmq",
            "provider": "com.tarantula.platform.service.persistence.messaging.RabbitMQBackupProvider"
        },
        {
            "enabled": true,
            "name": "webhook",
            "provider": "com.tarantula.platform.service.persistence.web.WebHookBackupProvider"
        }
        ]
    },
    "data-backup-router": {
        "enabled": true,
        "backup-provider-list":[{
            "enabled": false,
            "name": "rabbitmq",
            "provider": "com.tarantula.platform.service.persistence.messaging.RabbitMQBackupProvider"
        },
        {
            "enabled": true,
            "name": "webhook",
            "provider": "com.tarantula.platform.service.persistence.web.WebHookBackupProvider"
        }
        ]
    }
}