<?xml version="1.0" encoding="UTF-8"?>
<hazelcast xmlns="http://www.hazelcast.com/schema/config"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.hazelcast.com/schema/config
           http://www.hazelcast.com/schema/config/hazelcast-config-3.12.xsd">
    <group>
        <name>tarantula-integration</name>
    </group>
    <management-center enabled="false">http://10.0.0.6:8080/mancenter</management-center>
    <properties>
		<property name="hazelcast.logging.type">jdk</property>
        <property name="hazelcast.heartbeat.failuredetector.type">deadline</property>
        <property name="hazelcast.heartbeat.interval.seconds">5</property>
		<property name="hazelcast.max.no.heartbeat.seconds">120</property>
        <property name="hazelcast.socket.bind.any">false</property>
        <property name="hazelcast.connection.monitor.max.faults">1</property>
        <property name="hazelcast.executor.client.thread.count">8</property>
        <property name="hazelcast.executor.event.thread.count">8</property>
        <property name="hazelcast.shutdownhook.enabled">true</property>
        <property name="hazelcast.mancenter.enabled">false</property>
		<property name="hazelcast.phone.home.enabled">false</property>
        <property name="hazelcast.health.monitoring.level">OFF</property>
        <property name="hazelcast.discovery.enabled">true</property>
	</properties>
    <network>
        <port auto-increment="false">5702</port>
        <join>    
        	<multicast enabled="false"></multicast>
            <tcp-ip enabled="false">
                <member>10.142.0.5:5702</member>
                <member>10.142.0.2:5702</member>
            </tcp-ip>
            <aws enabled="false"></aws>
            <!--
            <discovery-strategies>
                <discovery-strategy enabled="true" class="com.tarantula.platform.service.cluster.TarantulaDiscoveryStrategy">
                    <properties>
                        <property name="tarantula-port">5702</property>
                        <property name="tarantula-scope">2</property>
                    </properties>
                </discovery-strategy>
            </discovery-strategies>
            -->
        </join>
    </network>
    <services>
        <service enabled="true">
            <name>AccessIndexService</name>
            <class-name>com.tarantula.platform.service.cluster.accessindex.AccessIndexClusterService</class-name>
        </service>

        <service enabled="true">
            <name>DeployService</name>
            <class-name>com.tarantula.platform.service.cluster.deployment.ClusterDeployService</class-name>
            <properties>
                <property name="tarantula-scope">2</property>
            </properties>
        </service>
        <service enabled="true">
            <name>RecoverService</name>
            <class-name>com.tarantula.platform.service.cluster.recover.ClusterRecoverService</class-name>
            <properties>
                <property name="tarantula-scope">2</property>
            </properties>
        </service>
        <service enabled="true">
            <name>DistributionTournamentService</name>
            <class-name>com.tarantula.platform.service.cluster.tournament.TournamentClusterService</class-name>
        </service>
        <service enabled="true">
            <name>DistributionItemService</name>
            <class-name>com.tarantula.platform.service.cluster.item.ItemClusterService</class-name>
        </service>
        <service enabled="true">
            <name>DistributionRoomService</name>
            <class-name>com.tarantula.platform.service.cluster.room.RoomClusterService</class-name>
        </service>
        <service enabled="true">
            <name>DistributionMetricsService</name>
            <class-name>com.tarantula.platform.service.cluster.metrics.MetricsClusterService</class-name>
        </service>
        <service enabled="true">
            <name>DistributionPresenceService</name>
            <class-name>com.tarantula.platform.service.cluster.presence.PresenceClusterService</class-name>
        </service>
    </services>
    <partition-group enabled="true" group-type="HOST_AWARE" />
    <map name="tarantula.map.small.*">
        <async-backup-count>1</async-backup-count>
        <eviction-policy>NONE</eviction-policy>
        <max-size>100</max-size>
    </map>
    <map name="tarantula.map.medium.*">
        <async-backup-count>1</async-backup-count>
        <eviction-policy>NONE</eviction-policy>
        <max-size>1000</max-size>
    </map>
    <map name="tarantula.map.large.*">
        <async-backup-count>1</async-backup-count>
        <eviction-policy>NONE</eviction-policy>
        <max-size>10000</max-size>
    </map>
    <multimap name="tarantula.index.*">
        <async-backup-count>1</async-backup-count>
        <value-collection-type>SET</value-collection-type>
    </multimap>
    <queue name="tarantula.queue.small.*">
        <max-size>100</max-size>
        <backup-count>1</backup-count>
    </queue>
    <queue name="tarantula.queue.medium.*">
        <max-size>1000</max-size>
        <backup-count>1</backup-count>
    </queue>
    <queue name="tarantula.queue.large.*">
        <max-size>10000</max-size>
        <backup-count>1</backup-count>
    </queue>
</hazelcast>
