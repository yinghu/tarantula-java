<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
		<type-id>tarantula</type-id>
		<type>lobby</type>
        <category>service</category>
        <access-mode>12</access-mode>
		<name>Heydere</name>
		<description>Tarantula  Service</description>

        <deploy-priority>130</deploy-priority>
		<application-list>
            <application>
                <type-id>tarantula</type-id>
                <subtype-id>plist01</subtype-id>
                <name>Friend</name>
                <type>application</type>
                <category>social</category>
                <singleton>true</singleton>
                <tag>tarantula/buddylist</tag>
                <view-id>buddy</view-id>
                <description>Tarantula Social Play List Service</description>
                <class-name>com.tarantula.platform.playlist.BuddyListApplication</class-name>
                <configuration-name>playlist</configuration-name>
                <response-label>buddyList</response-label>
            </application>
            <application>
                <type-id>tarantula</type-id>
                <subtype-id>hx01</subtype-id>
                <name>User State</name>
                <type>application</type>
                <category>onstate</category>
                <singleton>true</singleton>
                <tag>tarantula/onstate</tag>
                <description>On State Service</description>
                <class-name>com.tarantula.platform.playlist.OnStateApplication</class-name>
                <response-label>userState</response-label>
            </application>
            <application>
                <type-id>tarantula</type-id>
                <subtype-id>hx02</subtype-id>
                <name>Recently Play List</name>
                <type>application</type>
                <category>recentlyplaylist</category>
                <singleton>true</singleton>
                <tag>tarantula/recentlyplaylist</tag>
                <view-id>recentlyplaylist</view-id>
                <description>Recently Play List Service</description>
                <configuration-name>playlist</configuration-name>
                <class-name>com.tarantula.platform.playlist.RecentlyPlayListApplication</class-name>
                <response-label>recentlyList</response-label>
            </application>
            <!-- USER ACCESS ENTRY GATEWAY WILL WELL-KNOWN VIEW ID INDEX -->
		</application-list>
        <configuration-list>
            <configuration tag="playlist" priority="10" >
                <playlist type="playlist">
                    <property name="buddyListSize">16</property>
                    <property name="onPlaySize">3</property>
                    <property name="intervalOnSync">5</property>
                    <property name="actionBatchSize">1</property>
                </playlist>
                <playlist type="recentlyplaylist">
                    <property name="recentListSize">16</property>
                </playlist>
            </configuration>
            <configuration tag="listing" priority="10">
                <listing type="setup">
                    <property name="invitationPlayOnBuddyList">true</property>
                </listing>
            </configuration>
        </configuration-list>
	</lobby-context>
</tarantula>