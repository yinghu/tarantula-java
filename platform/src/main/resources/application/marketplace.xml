<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>market</type-id>
        <type>lobby</type>
        <category>service</category>
        <name>Marketplace</name>
        <access-mode>12</access-mode>
        <description>Tarantula Marketplace Service</description>

        <deploy-priority>20</deploy-priority>
        <application-list>
            <application>
                <type-id>market</type-id>
                <subtype-id>mp01</subtype-id>
                <name>Marketplace</name>
                <type>application</type>
                <category>marketplace</category>
                <singleton>true</singleton>
                <tag>marketplace</tag>
                <view-id>marketplace</view-id>
                <description>Tarantula Marketplace Service</description>
                <class-name>com.tarantula.platform.marketplace.MarketplaceApplication</class-name>
                <configuration-name>marketplace</configuration-name>
                <leader-board-header>presence</leader-board-header>
                <response-label>marketplace</response-label>
            </application>
        </application-list>
        <configuration-list>
            <configuration tag="marketplace" priority="10">
                <marketplace type="setup">
                    <property name="baseVirtualCredits">500000</property>
                    <property name="basePrice">100</property>
                    <property name="basePackageSize">4</property>
                </marketplace>
            </configuration>
        </configuration-list>
    </lobby-context>
</tarantula>