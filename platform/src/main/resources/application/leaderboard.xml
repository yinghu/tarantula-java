<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>leaderboard</type-id>
        <type>lobby</type>
        <category>service</category>
        <name>Leaderboard</name>
        <access-mode>12</access-mode>
        <description>Tarantula LeaderBoard Service</description>
        <deploy-priority>100</deploy-priority>
        <application-list>
            <application>
                <type-id>leaderboard</type-id>
                <subtype-id>ld01</subtype-id>
                <name>Leaderboard</name>
                <type>application</type>
                <singleton>true</singleton>
                <tag>leaderboard</tag>
                <view-id>leaderboard</view-id>
                <description>Tarantula Leaderboard Service</description>
                <class-name>com.tarantula.platform.leaderboard.LeaderBoardApplication</class-name>
                <configuration-name>leaderboard</configuration-name>
                <response-label>leaderboard</response-label>
            </application>
        </application-list>
        <configuration-list>
            <configuration tag="leaderboard" priority="10">
                <service-provider name="com.tarantula.platform.leaderboard.Top10LeaderBoardServiceProvider"/>
                <leaderboard type="setup">
                    <property name="name">Top10</property>
                </leaderboard>
            </configuration>
        </configuration-list>
    </lobby-context>
</tarantula>