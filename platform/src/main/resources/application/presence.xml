<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>presence</type-id>
        <type>lobby</type>
        <category>service</category>
        <access-mode>12</access-mode>
        <name>presence</name>
        <description>Tarantula Presence Service</description>
        <deploy-priority>400</deploy-priority>
        <application-list>
            <application>
                <type-id>presence</type-id>
                <subtype-id>presence-lobby</subtype-id>
                <name>Presence</name>
                <type>application</type>
                <singleton>true</singleton>
                <tag>presence/lobby</tag>
                <description>Tarantula Presence</description>
                <class-name>com.tarantula.platform.presence.PresenceApplication</class-name>
                <configuration-name>presence</configuration-name>
                <response-label>presence</response-label>
            </application>
        </application-list>
        <configuration-list>
            <configuration tag="presence" priority="10">
                <presence type="yearlyAccess">
                    <property name="price">1200</property>
                    <property name="currency">USD</property>
                </presence>
                <presence type="monthlyAccess">
                    <property name="price">120</property>
                    <property name="currency">USD</property>
                </presence>
            </configuration>
        </configuration-list>
        <view-list>
            <view type="dashboard">
                <property name="moduleResourceFile">admin/dashboard.view.html</property>
            </view>
            <view type="add.email">
                <property name="moduleResourceFile">admin/add.email.view.html</property>
            </view>
            <view type="upgrade.role">
                <property name="moduleResourceFile">admin/upgrade.role.view.html</property>
            </view>
            <view type="add.user">
                <property name="moduleResourceFile">admin/add.user.view.html</property>
            </view>
            <view type="create.game.cluster">
                <property name="moduleResourceFile">admin/create.game.cluster.view.html</property>
            </view>
            <view type="shopping.card">
                <property name="moduleResourceFile">admin/stripe.card.view.html</property>
            </view>
        </view-list>
    </lobby-context>
</tarantula>