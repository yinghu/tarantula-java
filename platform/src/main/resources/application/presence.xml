<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>presence</type-id>
        <type>lobby</type>
        <category>service</category>
        <access-mode>11</access-mode>
        <name>presence</name>
        <description>Tarantula Lobby Index</description>
        <view-id>presence</view-id>
        <deploy-priority>110</deploy-priority>
        <application-list>
            <application><!--could be exposing on login successful -->
                <type-id>presence</type-id>
                <subtype-id>tx04</subtype-id>
                <name>Presence</name>
                <type>application</type>
                <singleton>true</singleton>
                <tag>presence/lobby</tag>
                <description>Tarantula Presence</description>
                <class-name>com.tarantula.platform.presence.PresenceApplication</class-name>
                <configuration-name>presence</configuration-name>
                <response-label>presence</response-label>
            </application>
            <application>
                <type-id>presence</type-id>
                <subtype-id>pf01</subtype-id>
                <name>Profile</name>
                <type>application</type>
                <category>profile</category>
                <singleton>true</singleton>
                <tag>presence/profile</tag>
                <view-id>profile</view-id>
                <description>Tarantula Profile Service</description>
                <class-name>com.tarantula.platform.playmode.SingletonModuleApplication</class-name>
                <module-name>com.tarantula.platform.presence.ProfileModule</module-name>
                <configuration-name>profile</configuration-name>
                <response-label>profile</response-label>
            </application>
        </application-list>
        <configuration-list>
            <configuration tag="presence" priority="10">
                <presence type="setup">
                    <property name="lobbyListenerEnabled">false</property>
                    <property name="lobbyList">tarantula,market,leaderboard,level</property>
                </presence>
            </configuration>
            <configuration tag="profile" priority="10">
                <profile type="setup">
                    <property name="uploadChunkSize">1200000</property>
                    <property name="contentPath">/tarantula/content</property>
                </profile>
            </configuration>
        </configuration-list>
    </lobby-context>
</tarantula>