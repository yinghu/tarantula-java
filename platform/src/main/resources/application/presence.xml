<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>presence</type-id>
        <type>lobby</type>
        <category>service</category>
        <access-mode>12</access-mode>
        <name>presence</name>
        <description>Tarantula Presence Service</description>
        <deploy-priority>400</deploy-priority>
        <application-list>
            <application>
                <type-id>presence</type-id>
                <subtype-id>presence-lobby</subtype-id>
                <name>Presence</name>
                <type>application</type>
                <singleton>true</singleton>
                <tag>presence/lobby</tag>
                <description>Tarantula Presence</description>
                <class-name>com.tarantula.platform.presence.PresenceApplication</class-name>
                <configuration-name>presence</configuration-name>
                <response-label>presence</response-label>
            </application>
        </application-list>
        <configuration-list>
            <configuration tag="presence" priority="10">
                <presence type="yearlyAccess">
                    <property name="price">1200</property>
                    <property name="currency">USD</property>
                </presence>
                <presence type="monthlyAccess">
                    <property name="price">120</property>
                    <property name="currency">USD</property>
                </presence>
            </configuration>
        </configuration-list>
        <view-list>
            <view type="dashboard">
                <property name="moduleResourceFile">presence/dashboard.view.html</property>
            </view>
            <view type="add.email">
                <property name="moduleResourceFile">presence/add.email.view.html</property>
            </view>
            <view type="change.password">
                <property name="moduleResourceFile">presence/change.password.view.html</property>
            </view>
            <view type="upgrade.role">
                <property name="moduleResourceFile">presence/upgrade.role.view.html</property>
            </view>
            <view type="shopping.card">
                <property name="moduleResourceFile">presence/stripe.card.view.html</property>
            </view>
            <view type="api.index">
                <property name="moduleResourceFile">presence/api.index.view.html</property>
            </view>
            <view type="api.device.login">
                <property name="moduleResourceFile">presence/api.device.login.view.html</property>
            </view>
            <view type="api.register">
                <property name="moduleResourceFile">presence/api.register.view.html</property>
            </view>
            <view type="api.login">
                <property name="moduleResourceFile">presence/api.login.view.html</property>
            </view>
            <view type="api.set.json">
                <property name="moduleResourceFile">presence/api.set.json.view.html</property>
            </view>
            <view type="api.get.json">
                <property name="moduleResourceFile">presence/api.get.json.view.html</property>
            </view>
        </view-list>
    </lobby-context>
</tarantula>