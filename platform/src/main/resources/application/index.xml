<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>index</type-id><!-- mapping to lobbyTypeId on application descriptor-->
        <type>lobby</type>
        <category>service</category>
        <access-mode>10</access-mode>
        <name>Index</name>
        <deploy-priority>500</deploy-priority>
        <application-list>
            <application>
                <type-id>index</type-id>
                <name>User</name>
                <type>application</type>
                <tag>index/user</tag>
                <category>account</category>
                <class-name>com.tarantula.platform.presence.UserManagementApplication</class-name>
            </application>
        </application-list>
        <view-list>
            <view type="sign.in">
                <property name="moduleResourceFile">sign.in.view.html</property>
            </view>
            <view type="sign.up">
                <property name="moduleResourceFile">sign.up.view.html</property>
            </view>
            <view type="password.reset">
                <property name="moduleResourceFile">password.reset.view.html</property>
            </view>
            <view type="invalid.request">
                <property name="moduleResourceFile">invalid.request.view.html</property>
            </view>
        </view-list>
    </lobby-context>
</tarantula>