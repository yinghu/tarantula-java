<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>index</type-id><!-- mapping to lobbyTypeId on application descriptor-->
        <type>lobby</type>
        <category>service</category>
        <access-mode>10</access-mode>
        <name>Index</name>
        <description>Tarantula Lobby Index</description>
        <deploy-priority>500</deploy-priority>
        <application-list>
            <application>
                <type-id>index</type-id>
                <name>User</name>
                <type>application</type>
                <tag>index/user</tag>
                <description>Tarantula User Management</description>
                <class-name>com.tarantula.platform.presence.UserManagementApplication</class-name>
            </application>

        </application-list>
        <configuration-list>
            <configuration tag="user" type="setup">
                <property name="lobbyId">presence</property>
                <property name="activated">false</property>
                <property name="initialBalance">1000000</property>
                <property name="roleName">player</property>
                <property name="root">root</property>
                <property name="password">root</property>
            </configuration>
        </configuration-list>
        <view-list>
            <view type="sign.in">
                <property name="moduleResourceFile">sign.in.view.html</property>
            </view>
            <view type="sign.up">
                <property name="moduleResourceFile">sign.up.view.html</property>
            </view>
            <view type="password.reset">
                <property name="moduleResourceFile">password.reset.view.html</property>
            </view>
            <view type="invalid.request">
                <property name="moduleResourceFile">invalid.request.view.html</property>
            </view>
        </view-list>
    </lobby-context>
</tarantula>