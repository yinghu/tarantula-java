<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>index</type-id><!-- mapping to lobbyTypeId on application descriptor-->
        <type>lobby</type>
        <category>service</category>
        <access-mode>10</access-mode>
        <name>Index</name>
        <description>Tarantula Lobby Index</description>
        <deploy-priority>500</deploy-priority>
        <application-list>
            <application>
                <type-id>index</type-id>
                <subtype-id>index-user</subtype-id>
                <name>User</name>
                <type>application</type>
                <singleton>true</singleton>
                <tag>index/user</tag>
                <description>Tarantula User Management</description>
                <class-name>com.tarantula.platform.presence.UserManagementApplication</class-name>
                <configuration-name>user</configuration-name>
                <leader-board-header>presence</leader-board-header>
                <response-label>user</response-label>
            </application>
            <application>
                <type-id>index</type-id>
                <subtype-id>index-lobby</subtype-id>
                <name>Index</name>
                <type>application</type>
                <category>index</category>
                <singleton>true</singleton>
                <tag>index/lobby</tag>
                <description>Index Service</description>
                <configuration-name>index</configuration-name>
                <class-name>com.tarantula.platform.presence.IndexApplication</class-name>
                <response-label>index</response-label>
            </application>
        </application-list>
        <configuration-list>
            <configuration tag="user" priority="10">
                <user type="setup">
                    <property name="lobbyId">presence</property>
                    <property name="activated">true</property>
                    <property name="initialBalance">1000000</property>
                    <property name="roleName">player</property>
                    <property name="root">root</property>
                    <property name="password">root</property>
                </user>
            </configuration>
        </configuration-list>
    </lobby-context>
</tarantula>