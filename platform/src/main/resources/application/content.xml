<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>content</type-id>
        <type>lobby</type>
        <category>service</category>
        <name>Content</name>
        <access-control>12</access-control>
        <description>Tarantula Content Service</description>
        <deploy-priority>100</deploy-priority>
        <application-list>
            <application>
                <type-id>content</type-id>
                <subtype-id>content-avatar</subtype-id>
                <name>Avatar</name>
                <type>application</type>
                <category>avatar</category>
                <singleton>true</singleton>
                <tag>content/avatar</tag>
                <description>Tarantula Content Avatar Service</description>
                <class-name>com.tarantula.platform.presence.AvatarContentApplication</class-name>
                <configuration-name>content</configuration-name>
                <response-label>content</response-label>
            </application>
        </application-list>
        <configuration-list>
            <configuration tag="content" priority="10">
                <content type="setup">
                    <property name="uploadChunkSize">1200000</property>
                    <property name="contentPath">/tarantula/content</property>
                </content>
            </configuration>
        </configuration-list>
    </lobby-context>
</tarantula>