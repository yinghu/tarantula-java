<?xml version="1.0" encoding="UTF-8"?>
<tarantula>
    <lobby-context>
        <type-id>demo-sync</type-id>
        <type>lobby</type>
        <category>game</category>
        <icon>html/blackjack/blackjack_icon.png</icon>
        <view-id>game.lobby</view-id>
        <tag>demo-sync</tag>
        <name>DemoSync</name>
        <access-mode>12</access-mode>
        <deploy-code>1</deploy-code>
        <description>Tarantula Demo Sync</description>
        <application-list>
            <application>
                <type-id>demo-sync</type-id>
                <subtype-id>demo-sync</subtype-id>
                <name>DemoSync</name>
                <type>application</type>
                <category>lobby</category>
                <singleton>true</singleton>
                <tag>demo-sync</tag>
                <description>Tarantula Demo Lobby Service</description>
                <class-name>com.tarantula.platform.playmode.GameLobbyApplication</class-name>
                <deploy-priority>15</deploy-priority>
                <configuration-name>demo-sync</configuration-name>
            </application>
            <application>
                <type-id>demo-sync</type-id>
                <subtype-id>demo-sync-a</subtype-id>
                <view-id>demo.sync.game</view-id>
                <name>DemoSync1</name>
                <type>application</type>
                <category>casino</category>
                <description>Tarantula Demo Sync Game</description>
                <class-name>com.tarantula.platform.playmode.DynamicModuleApplication</class-name>
                <entry-cost>5000</entry-cost>
                <capacity>10</capacity>
                <max-instances-per-partition>10</max-instances-per-partition>
                <instances-on-startup-per-partition>1</instances-on-startup-per-partition>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <max-idles-on-instance>3</max-idles-on-instance>
                <timeout-on-instance>300</timeout-on-instance><!--time out seconds per idle-->
                <configuration-name>demo-sync</configuration-name>
                <configuration-type>v1</configuration-type>
                <code-base>/development/boost/target/tarantula-boost-1.0.jar</code-base>
                <module-name>com.tarantula.boost.Demo</module-name>
            </application>
            <application>
                <type-id>demo-sync</type-id>
                <subtype-id>demo-sync-b</subtype-id>
                <view-id>demo.sync.game</view-id>
                <name>DemoSync2</name>
                <type>application</type>
                <category>casino</category>
                <description>Tarantula Demo Sync Game</description>
                <class-name>com.tarantula.platform.playmode.DynamicModuleApplication</class-name>
                <entry-cost>5000</entry-cost>
                <capacity>10</capacity>
                <instances-on-startup-per-partition>1</instances-on-startup-per-partition>
                <max-instances-per-partition>10</max-instances-per-partition>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <max-idles-on-instance>3</max-idles-on-instance>
                <timeout-on-instance>300</timeout-on-instance><!--time out seconds per idle-->
                <configuration-name>demo-sync</configuration-name>
                <configuration-type>v1</configuration-type>
                <code-base>/development/boost/target/tarantula-boost-1.0.jar</code-base>
                <module-name>com.tarantula.boost.Demo</module-name>
            </application>
            <application>
                <type-id>demo-sync</type-id>
                <subtype-id>demo-sync-c</subtype-id>
                <view-id>demo.sync.game</view-id>
                <name>DemoSync3</name>
                <type>application</type>
                <category>casino</category>
                <description>Tarantula Demo Sync Game</description>
                <class-name>com.tarantula.platform.playmode.DynamicModuleApplication</class-name>
                <entry-cost>5000</entry-cost>
                <capacity>10</capacity>
                <instances-on-startup-per-partition>1</instances-on-startup-per-partition>
                <max-instances-per-partition>10</max-instances-per-partition>
                <deploy-priority>10</deploy-priority>
                <deploy-version>1</deploy-version>
                <max-idles-on-instance>3</max-idles-on-instance>
                <timeout-on-instance>300</timeout-on-instance><!--time out seconds per idle-->
                <configuration-name>demo-sync</configuration-name>
                <configuration-type>v1</configuration-type>
                <code-base>/development/boost/target/tarantula-boost-1.0.jar</code-base>
                <module-name>com.tarantula.boost.Demo</module-name>
            </application>
        </application-list>
        <view-list>
            <view type="demo.sync.game">
                <property name="flag">HD2</property>
                <property name="moduleFile">html/demo/demo.sync.game.module.js</property>
                <property name="moduleName">DemoSyncGame</property>
                <property name="moduleResourceFile">html/demo/demo.sync.game.view.html</property>
            </view>
        </view-list>

        <configuration-list>
            <configuration tag="demo-sync" priority="10">
                <demo-sync type="v1">
                    <property name="seats">10</property>
                    <property name="deckSize">2</property>
                    <property name="minWager">100</property>
                    <property name="maxWager">1000</property>
                </demo-sync>
            </configuration>
        </configuration-list>

    </lobby-context>
</tarantula>