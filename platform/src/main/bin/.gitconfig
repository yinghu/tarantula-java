[user]
	email = yinghu.lu@gmail.com
	name = yingh
[credential]
	helper = store
	helper = !aws-vault exec pantheon-dev -- aws codecommit credential-helper $@
[core]
	autocrlf = true
[http]
	postBuffer = 524288000
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
