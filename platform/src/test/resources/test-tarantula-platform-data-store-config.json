{
    "data-source": {
        "name" : "tarantula",
        "provider" : "com.icodesoftware.lmdb.LMDBDataStoreProvider",
        "env-settings": [
            {"name": "data","path": "tarantula/data","mbSize": 0,"enabled": true},
            {"name": "integration","path": "tarantula/integration","mbSize": 0,"enabled": true},
            {"name": "index","path": "tarantula/index","mbSize": 0,"enabled": true},
            {"name": "log","path": "tarantula/log","mbSize": 0,"enabled": true},
            {"name": "local","path": "tarantula/local","mbSize": 0,"enabled": true}
        ],
        "migration": {
            "listeners": [
                {"name":"com.tarantula.platform.service.persistence.DataMigrationListener","enabled": false}
            ]
        }
    }
}